{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reposeal.dev/spec/capability-manifest-v1.schema.json",
  "title": "RepoSeal Capability Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "identities", "permissions"],
  "properties": {
    "apiVersion": { "const": "reposeal.dev/v1" },
    "kind": { "const": "CapabilityManifest" },
    "metadata": { "type": "object", "required": ["name", "version"], "properties": { "name": { "type": "string" }, "version": { "type": "string" } }, "additionalProperties": false },
    "identities": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "domains": { "type": "array", "items": { "type": "string", "format": "hostname" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "permissions": { "type": "object" },
    "provenance": { "type": "array", "items": { "type": "object" } }
  }
}

