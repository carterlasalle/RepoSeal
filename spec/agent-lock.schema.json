{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reposeal.dev/spec/agent-lock-v1.schema.json",
  "title": "RepoSeal agent.lock v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "components"],
  "properties": {
    "version": { "const": 1 },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "source", "integrity", "permissions", "dependencies", "approvals", "reviewed_at", "entry_hash"],
      "properties": {
        "id": { "type": "string", "minLength": 3, "maxLength": 2048 },
        "type": { "enum": ["repository", "package", "agent-skill", "mcp-server", "plugin", "download"] },
        "version": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "source": { "$ref": "#/$defs/source" },
        "integrity": { "type": "object" },
        "permissions": { "type": "object" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "instruction_hash": { "type": ["string", "null"], "pattern": "^(sha256:[0-9a-f]{64})?$" },
        "provenance": { "type": "array", "items": { "type": "object" } },
        "approvals": { "type": "array", "items": { "type": "object" } },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "entry_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "canonical", "verified_owner"],
      "properties": {
        "requested": { "type": "string" },
        "canonical": { "type": "string" },
        "verified_owner": { "type": "boolean" }
      }
    }
  }
}

