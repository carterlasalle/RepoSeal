{
  "name": "@reposeal/sdk",
  "version": "1.0.0",
  "description": "Typed TypeScript SDK for the RepoSeal supply-chain firewall",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
